#!/bin/sh
. "$(dirname "$0")/_/husky.sh"

# Run lint-staged for staged files
npx lint-staged

# Fail if any console.log is found in staged files
if git diff --cached --name-only --diff-filter=ACM | grep -E '\.(js|jsx|ts|tsx)$' | xargs grep -n 'console\.log'; then
  echo '❌ Commit aborted: console.log found in staged files.'
  exit 1
fi

# Type check (fail on error)
npx tsc --noEmit
